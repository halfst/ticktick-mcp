# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Credentials are read from the environment ONLY — never commit real values.
#
# Pick ONE auth mode:
#   A) Session token  — required if your account has 2FA (recommended).
#   B) Username + password — only works on accounts WITHOUT 2FA.

# --- Mode A: session token (use this if 2FA is enabled) ---
# Log into TickTick in a browser, complete any 2FA prompt, then copy the value
# of the `t` cookie (DevTools -> Application/Storage -> Cookies -> ticktick.com).
# Password login is skipped entirely. This token can't be auto-refreshed; when it
# expires, paste a fresh one.
# TICKTICK_SESSION_TOKEN=paste-the-t-cookie-value-here

# --- Mode B: username + password (no-2FA accounts only) ---
# The v2 web API signin has no second-factor step, so this fails with 2FA on.
# Logins from a new IP may also face a captcha / device challenge (see README).
TICKTICK_USERNAME=you@example.com
TICKTICK_PASSWORD=your-password

# --- Optional ---
# Where to cache the session token so we don't log in on every start.
# Defaults to ${XDG_CACHE_HOME:-~/.cache}/ticktick-mcp/session.json.
# In Docker this is set to a path on a persisted volume (see compose.yaml).
# TICKTICK_TOKEN_CACHE=/data/session.json

# Default IANA timezone for TIMED tasks created without an explicit zone.
# All-day tasks ignore this (they are stored at UTC midnight). Defaults to UTC.
# TICKTICK_TIMEZONE=America/Chicago

# Transport. "stdio" (default) for an MCP host that spawns the process; "http"
# for a long-running server (the Docker Compose service uses http). Host/port
# apply to http only.
# TICKTICK_MCP_TRANSPORT=stdio
# TICKTICK_MCP_HOST=0.0.0.0
# TICKTICK_MCP_PORT=8000
